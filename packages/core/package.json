{
  "name": "@hobom-grid/core",
  "version": "0.1.2",
  "description": "Headless, framework-agnostic data grid engine — virtualization, interaction, editing",
  "license": "MIT",
  "author": "HoBom (https://github.com/HoBom-s)",
  "repository": {
    "type": "git",
    "url": "https://github.com/HoBom-s/hobom-grid.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/HoBom-s/hobom-grid#readme",
  "bugs": "https://github.com/HoBom-s/hobom-grid/issues",
  "keywords": [
    "grid",
    "datagrid",
    "headless",
    "virtualization",
    "table",
    "spreadsheet"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "bench": "vitest bench",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {}
}
