{
  "name": "@hobom-grid/react",
  "version": "0.2.0",
  "description": "React adapter for @hobom-grid/core — virtualized data grid component and hooks",
  "license": "MIT",
  "author": "HoBom (https://github.com/HoBom-s)",
  "repository": {
    "type": "git",
    "url": "https://github.com/HoBom-s/hobom-grid.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/HoBom-s/hobom-grid#readme",
  "bugs": "https://github.com/HoBom-s/hobom-grid/issues",
  "keywords": [
    "grid",
    "datagrid",
    "react",
    "virtualization",
    "table",
    "spreadsheet",
    "hooks"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@hobom-grid/core": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^29.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  }
}
