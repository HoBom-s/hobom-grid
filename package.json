{
  "name": "hobom-grid",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "prepare": "husky install",
    "dev": "turbo dev",
    "dev:examples": "pnpm --filter examples-react dev",
    "typecheck": "turbo typecheck",
    "build": "turbo build",
    "build:core": "pnpm -w --filter @hobom-grid/core build",
    "build:react": "pnpm -w --filter @hobom-grid/react build",
    "bench": "turbo run bench",
    "bench:core": "pnpm -w --filter @hobom-grid/core bench",
    "test": "turbo run test",
    "coverage": "turbo run coverage",
    "test:core": "pnpm -w --filter @hobom-grid/core test",
    "test:core:watch": "pnpm -w --filter @hobom-grid/core test:watch",
    "coverage:core": "pnpm -w --filter @hobom-grid/core coverage",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "docs:api": "pnpm --filter docs api",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "pnpm -w knip:core && pnpm -w knip:react",
    "knip:core": "knip --workspace packages/core --exports",
    "knip:react": "knip --workspace packages/react --exports",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,cjs,mjs}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
